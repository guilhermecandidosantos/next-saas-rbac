# ===================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# ===================================

# ⚠️ IMPORTANTE: Este arquivo é apenas um TEMPLATE de referência!
# 
# No projeto, as variáveis de ambiente são configuradas diretamente
# no Systemd Service (/etc/systemd/system/next-saas-api.service)
# em produção, para maior segurança e isolamento.
#
# Use este arquivo apenas como referência para saber quais variáveis
# configurar no Systemd ou para desenvolvimento local com Docker.

# ===================================
# CONFIGURAÇÃO DO BANCO DE DADOS
# ===================================

# URL de conexão com PostgreSQL
# Desenvolvimento (Docker): postgresql://docker:docker@localhost:5432/next-saas
# Produção (Neon): postgresql://usuario:senha@db.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://docker:docker@localhost:5432/next-saas"

# ===================================
# CONFIGURAÇÃO DA API
# ===================================

# Ambiente de execução
NODE_ENV="development"

# Segredo para assinatura de tokens JWT (gere uma string aleatória segura)
# Exemplo de geração: openssl rand -base64 32
JWT_SECRET="seu-jwt-secret-super-seguro-aqui"

# URL base da API
# Desenvolvimento: http://localhost:3333
# Produção: https://api.seudominio.com
API_URL="http://localhost:3333"

# ===================================
# CONFIGURAÇÃO DO FRONTEND
# ===================================

# URL pública da API (usada pelo frontend)
# Desenvolvimento: http://localhost:3333
# Produção: https://api.seudominio.com
NEXT_PUBLIC_API_URL="http://localhost:3333"

# ===================================
# GITHUB OAUTH
# ===================================

# Credenciais do GitHub OAuth App
# Crie em: https://github.com/settings/developers
GITHUB_CLIENT_ID="seu-github-client-id"
GITHUB_CLIENT_SECRET="seu-github-client-secret"

# URL de callback após autenticação
# Desenvolvimento: http://localhost:3000/api/auth/callback
# Produção: https://app.seudominio.com/api/auth/callback
GITHUB_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# ===================================
# CONFIGURAÇÃO DE EMAIL (SMTP)
# ===================================

# Servidor SMTP
# Exemplos:
# - Gmail: smtp.gmail.com
# - Outlook: smtp.office365.com
# - SendGrid: smtp.sendgrid.net
# - Mailgun: smtp.mailgun.org
HOST_EMAIL="smtp.seuservidor.com"

# Porta SMTP
# 587 - TLS (recomendado)
# 465 - SSL
# 25 - Não criptografado (não recomendado)
PORT_EMAIL="587"

# Credenciais de autenticação SMTP
USER_EMAIL="noreply@seudominio.com"
PASSWORD_EMAIL="senha-do-email"

# ===================================
# NOTAS IMPORTANTES
# ===================================

# 1. NUNCA commite este arquivo com dados reais no Git!
# 2. Em produção, use variáveis de ambiente do sistema ou secrets manager
# 3. Para desenvolvimento, copie este arquivo para .env e preencha os valores
# 4. Gere senhas e secrets fortes e únicos para produção
# 5. Use HTTPS em produção (nunca HTTP)
# 6. Configure CORS adequadamente na API para produção

# ===================================
# COMANDOS ÚTEIS
# ===================================

# Gerar JWT_SECRET seguro:
# openssl rand -base64 32

# Testar conexão SMTP:
# telnet smtp.seuservidor.com 587

# Verificar variáveis carregadas:
# node -e "require('dotenv').config(); console.log(process.env)"
